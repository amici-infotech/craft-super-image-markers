{# Replace `general.imageMarker` with your global/entry field handle. #}
{% set imageMarker = general.imageMarker %}

{# `process()` preloads the image and related marker entries before the loop renders. #}
{% set imageMarker = imageMarker ? imageMarker.process() : null %}

{# Guard against missing images or empty marker collections before drawing the map. #}
{% set hasMarkers = imageMarker and not imageMarker.image.isEmpty() and not imageMarker.markers.isEmpty() %}
{% set image = hasMarkers ? imageMarker.image.one() : null %}
{% set markers = hasMarkers ? imageMarker.markers.all() : [] %}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Super Image Markers - Modal Example</title>
    {# Tailwind CDN is used here only to keep this example copy-paste friendly. #}
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <main class="mx-auto my-10 w-[min(1120px,calc(100%_-_32px))]">
        <nav class="mb-6 flex flex-wrap gap-4 text-sm font-medium">
            {# Update these URLs to match wherever you copy the example templates. #}
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}/modal">Modal</a>
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}">Tooltip</a>
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}/info-window">Info Window</a>
        </nav>

        <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">Super Image Markers</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-950">Modal Marker Example</h1>
            <p class="mt-3 max-w-2xl text-slate-600">Click a marker to open a modal with entry title, ID, dates, and marker position.</p>
        </div>

        {% if hasMarkers %}
            {# The image wrapper is relative so modal trigger buttons can sit at marker percentages. #}
            <div class="relative inline-block max-w-full overflow-hidden rounded-2xl bg-white shadow-2xl shadow-slate-900/10">
                <img class="block h-auto max-w-full" src="{{ image.url }}" alt="{{ image.title }}">

                {% for item in markers %}
                    {# Each marker contains x/y percentages, color, entryId, and a preloaded entry reference. #}
                    {% set marker = item.marker %}
                    {% set entry = marker.entry.one() %}

                    {% if entry %}
                        {# Data attributes give the small script below everything it needs for the modal. #}
                        <button
                            class="absolute size-6 -translate-x-1/2 -translate-y-1/2 cursor-pointer rounded-full border-[3px] border-white shadow-lg shadow-black/35 outline-none ring-offset-2 transition hover:scale-110 focus-visible:scale-110 focus-visible:ring-2 focus-visible:ring-slate-900"
                            type="button"
                            style="left: {{ marker.x }}%; top: {{ marker.y }}%; background-color: {{ marker.color }};"
                            aria-label="Open {{ entry.title }}"
                            data-title="{{ entry.title|e('html_attr') }}"
                            data-id="{{ entry.id }}"
                            data-slug="{{ entry.slug|e('html_attr') }}"
                            data-url="{{ entry.url ?? '' }}"
                            data-date-created="{{ entry.dateCreated|date('M j, Y g:ia') }}"
                            data-date-updated="{{ entry.dateUpdated|date('M j, Y g:ia') }}"
                            data-x="{{ marker.x }}"
                            data-y="{{ marker.y }}"
                        ></button>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            {# Friendly empty state for new installs or content that has not been configured yet. #}
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
                No image marker field content found in the <code>general</code> global set.
            </div>
        {% endif %}
    </main>

    {# One reusable modal is populated from the clicked marker's data attributes. #}
    <div class="fixed inset-0 hidden place-items-center bg-slate-950/60 p-6" id="marker-modal" aria-hidden="true">
        <div class="w-[min(460px,100%)] overflow-hidden rounded-2xl bg-white shadow-2xl shadow-black/30" role="dialog" aria-modal="true" aria-labelledby="marker-modal-title">
            <div class="flex items-center justify-between gap-4 border-b border-slate-200 px-6 py-5">
                <h2 class="text-xl font-semibold text-slate-950" id="marker-modal-title">Entry</h2>
                <button class="close text-3xl leading-none text-slate-500 hover:text-slate-950" type="button" aria-label="Close">&times;</button>
            </div>
            <div class="grid gap-3 p-6 text-sm" id="marker-modal-body"></div>
        </div>
    </div>

    <script>
        // Cache modal elements once so every marker click can reuse the same DOM.
        const modal = document.getElementById('marker-modal');
        const modalTitle = document.getElementById('marker-modal-title');
        const modalBody = document.getElementById('marker-modal-body');

        document.querySelectorAll('[data-title][data-id]').forEach((button) => {
            button.addEventListener('click', () => {
                // Fill the modal from the marker button's data attributes.
                modalTitle.textContent = button.dataset.title;
                modalBody.innerHTML = `
                    <div class="grid grid-cols-[120px_1fr] gap-2"><span class="text-slate-500">ID</span><strong>${button.dataset.id}</strong></div>
                    <div class="grid grid-cols-[120px_1fr] gap-2"><span class="text-slate-500">Slug</span><strong>${button.dataset.slug}</strong></div>
                    <div class="grid grid-cols-[120px_1fr] gap-2"><span class="text-slate-500">Created</span><strong>${button.dataset.dateCreated}</strong></div>
                    <div class="grid grid-cols-[120px_1fr] gap-2"><span class="text-slate-500">Updated</span><strong>${button.dataset.dateUpdated}</strong></div>
                    <div class="grid grid-cols-[120px_1fr] gap-2"><span class="text-slate-500">Marker</span><strong>X ${button.dataset.x}%, Y ${button.dataset.y}%</strong></div>
                    ${button.dataset.url ? `<p class="pt-2"><a class="font-medium text-blue-600 hover:text-blue-800" href="${button.dataset.url}">View entry</a></p>` : ''}
                `;
                modal.classList.remove('hidden');
                modal.classList.add('grid');
                modal.setAttribute('aria-hidden', 'false');
            });
        });

        modal.addEventListener('click', (event) => {
            // Close when clicking the overlay or the close button.
            if (event.target === modal || event.target.closest('.close')) {
                modal.classList.add('hidden');
                modal.classList.remove('grid');
                modal.setAttribute('aria-hidden', 'true');
            }
        });
    </script>
</body>
</html>
