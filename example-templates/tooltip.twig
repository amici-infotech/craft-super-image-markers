{# Replace `general.imageMarker` with your global/entry field handle. #}
{% set imageMarker = general.imageMarker %}

{# `process()` preloads the image and marker entries so the loop below avoids one query per marker. #}
{% set imageMarker = imageMarker ? imageMarker.process() : null %}

{# Only render the demo map when both a valid image and marker rows exist. #}
{% set hasMarkers = imageMarker and not imageMarker.image.isEmpty() and not imageMarker.markers.isEmpty() %}
{% set image = hasMarkers ? imageMarker.image.one() : null %}
{% set markers = hasMarkers ? imageMarker.markers.all() : [] %}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Super Image Markers - Tooltip Example</title>
    {# Tailwind CDN is used here only to keep this example copy-paste friendly. #}
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Center each marker on the saved percentage coordinate. */
        .marker-wrap {
            transform: translate(-50%, -50%);
        }

        /* Draw the small tooltip pointer without extra markup. */
        .tooltip-bubble::after {
            content: "";
            position: absolute;
            left: 50%;
            top: 100%;
            border: 8px solid transparent;
            border-top-color: #111827;
            transform: translateX(-50%);
        }
    </style>
</head>
<body class="min-h-screen bg-stone-50 text-slate-800 antialiased">
    <main class="mx-auto my-10 w-[min(1120px,calc(100%_-_32px))]">
        <nav class="mb-6 flex flex-wrap gap-4 text-sm font-medium">
            {# Update these URLs to match wherever you copy the example templates. #}
            <a class="text-blue-600 hover:text-blue-800" href="/suoer-image-markers/modal">Modal</a>
            <a class="text-blue-600 hover:text-blue-800" href="/suoer-image-markers">Tooltip</a>
            <a class="text-blue-600 hover:text-blue-800" href="/suoer-image-markers/info-window">Info Window</a>
        </nav>

        <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-600">Super Image Markers</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-950">Tooltip Marker Example</h1>
            <p class="mt-3 max-w-2xl text-slate-600">Hover or focus a marker to show entry details from the global image marker field.</p>
        </div>

        {% if hasMarkers %}
            {# The image container is positioned so marker wrappers can use absolute percentage coordinates. #}
            <div class="relative inline-block max-w-full rounded-2xl bg-white shadow-2xl shadow-slate-900/10">
                <img class="block h-auto max-w-full rounded-2xl" src="{{ image.url }}" alt="{{ image.title }}">

                {% for item in markers %}
                    {# Each collection item returns itself via `.marker` for a readable frontend API. #}
                    {% set marker = item.marker %}
                    {# After `process()`, this reads from the preloaded entry reference. #}
                    {% set entry = marker.entry.one() %}

                    {% if entry %}
                        {# `marker.x` and `marker.y` are percentages saved by the Control Panel field. #}
                        <div class="marker-wrap group absolute" style="left: {{ marker.x }}%; top: {{ marker.y }}%;">
                            <button
                                class="block size-6 cursor-help rounded-full border-[3px] border-white shadow-lg shadow-black/35 outline-none ring-offset-2 transition group-hover:scale-110 group-focus-visible:scale-110 group-focus-visible:ring-2 group-focus-visible:ring-slate-900"
                                type="button"
                                style="background-color: {{ marker.color }};"
                                aria-describedby="marker-tooltip-{{ loop.index }}"
                            ></button>
                            {# Hover/focus keeps the tooltip accessible to keyboard users. #}
                            <div
                                class="tooltip-bubble pointer-events-none absolute bottom-[calc(100%_+_12px)] left-1/2 z-10 w-60 -translate-x-1/2 translate-y-2 rounded-xl bg-slate-950 p-3 text-white opacity-0 shadow-2xl shadow-black/30 transition group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100"
                                id="marker-tooltip-{{ loop.index }}"
                                role="tooltip"
                            >
                                <h2 class="mb-1 text-base font-semibold">{{ entry.title }}</h2>
                                <p class="text-sm text-slate-300">ID: {{ entry.id }}</p>
                                <p class="text-sm text-slate-300">Created: {{ entry.dateCreated|date('M j, Y') }}</p>
                                <p class="text-sm text-slate-300">Marker: X {{ marker.x }}%, Y {{ marker.y }}%</p>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            {# Friendly empty state for new installs or content that has not been configured yet. #}
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
                No image marker field content found in the <code>general</code> global set.
            </div>
        {% endif %}
    </main>
</body>
</html>
