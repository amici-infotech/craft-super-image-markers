{# Replace `general.imageMarker` with your global/entry field handle. #}
{% set imageMarker = general.imageMarker %}

{# `process()` preloads the image and related marker entries before the loop renders. #}
{% set imageMarker = imageMarker ? imageMarker.process() : null %}

{# Guard against missing images or empty marker collections before drawing the map. #}
{% set hasMarkers = imageMarker and not imageMarker.image.isEmpty() and not imageMarker.markers.isEmpty() %}
{% set image = hasMarkers ? imageMarker.image.one() : null %}
{% set markers = hasMarkers ? imageMarker.markers.all() : [] %}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Super Image Markers - Info Window Example</title>
    {# Tailwind CDN is used here only to keep this example copy-paste friendly. #}
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Rotate the round marker into a classic map-pin shape. */
        .pin {
            transform: translate(-50%, -100%) rotate(-45deg);
            border-radius: 50% 50% 50% 0;
        }

        /* Anchor the info window above the clicked marker coordinate. */
        .info-window {
            transform: translate(-50%, calc(-100% - 26px));
        }

        /* Draw the info-window tail without extra markup. */
        .info-window::after {
            content: "";
            position: absolute;
            left: 50%;
            top: 100%;
            transform: translateX(-50%);
            border: 10px solid transparent;
            border-top-color: #fff;
        }
    </style>
</head>
<body class="min-h-screen bg-emerald-50 text-slate-800 antialiased">
    <main class="mx-auto my-10 w-[min(1120px,calc(100%_-_32px))]">
        <nav class="mb-6 flex flex-wrap gap-4 text-sm font-medium">
            {# Update these URLs to match wherever you copy the example templates. #}
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}/modal">Modal</a>
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}">Tooltip</a>
            <a class="text-blue-600 hover:text-blue-800" href="/{{ craft.app.request.getSegment(1) }}/info-window">Info Window</a>
        </nav>

        <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Super Image Markers</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-950">Map Info Window Example</h1>
            <p class="mt-3 max-w-2xl text-slate-600">Click a map pin to open an anchored info window.</p>
        </div>

        {% if hasMarkers %}
            {# The inner wrapper is relative so pins and the single info window share the same coordinate space. #}
            <div class="inline-block max-w-full rounded-3xl bg-white p-3 shadow-2xl shadow-slate-900/10">
                <div class="relative inline-block max-w-full" id="image-map">
                    <img class="block h-auto max-w-full rounded-2xl" src="{{ image.url }}" alt="{{ image.title }}">

                    {% for item in markers %}
                        {# Each marker contains x/y percentages, color, entryId, and a preloaded entry reference. #}
                        {% set marker = item.marker %}
                        {% set entry = marker.entry.one() %}

                        {% if entry %}
                            {# Data attributes let the script move and populate the shared info window. #}
                            <button
                                class="pin absolute size-7 cursor-pointer border-[3px] border-white shadow-lg shadow-black/35 outline-none ring-offset-2 focus-visible:ring-2 focus-visible:ring-slate-900"
                                type="button"
                                style="left: {{ marker.x }}%; top: {{ marker.y }}%; background-color: {{ marker.color }};"
                                aria-label="Open {{ entry.title }}"
                                data-title="{{ entry.title|e('html_attr') }}"
                                data-id="{{ entry.id }}"
                                data-slug="{{ entry.slug|e('html_attr') }}"
                                data-date="{{ entry.dateCreated|date('M j, Y') }}"
                                data-url="{{ entry.url ?? '' }}"
                                data-x="{{ marker.x }}"
                                data-y="{{ marker.y }}"
                            >
                                <span class="absolute inset-1.5 rounded-full bg-white"></span>
                            </button>
                        {% endif %}
                    {% endfor %}

                    {# One reusable info window is positioned at the active marker's x/y percentages. #}
                    <article class="info-window absolute z-10 hidden w-[min(300px,calc(100vw_-_48px))] rounded-2xl bg-white p-4 shadow-2xl shadow-slate-900/25" id="info-window" aria-live="polite">
                        <button class="info-close absolute right-2 top-2 text-xl leading-none text-slate-500 hover:text-slate-950" type="button" aria-label="Close">&times;</button>
                        <h2 class="mb-3 pr-6 text-lg font-semibold text-slate-950" id="info-title"></h2>
                        <dl class="grid grid-cols-[90px_1fr] gap-x-3 gap-y-2 text-sm" id="info-details"></dl>
                    </article>
                </div>
            </div>
        {% else %}
            {# Friendly empty state for new installs or content that has not been configured yet. #}
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
                No image marker field content found in the <code>general</code> global set.
            </div>
        {% endif %}
    </main>

    <script>
        // Cache the shared info-window elements once.
        const infoWindow = document.getElementById('info-window');
        const infoTitle = document.getElementById('info-title');
        const infoDetails = document.getElementById('info-details');

        document.querySelectorAll('.pin').forEach((marker) => {
            marker.addEventListener('click', () => {
                // Move the info window to the marker's saved percentage coordinate.
                infoWindow.style.left = `${marker.dataset.x}%`;
                infoWindow.style.top = `${marker.dataset.y}%`;
                // Fill the info window from the clicked marker's data attributes.
                infoTitle.textContent = marker.dataset.title;
                infoDetails.innerHTML = `
                    <dt class="text-slate-500">ID</dt><dd class="font-semibold">${marker.dataset.id}</dd>
                    <dt class="text-slate-500">Slug</dt><dd class="font-semibold">${marker.dataset.slug}</dd>
                    <dt class="text-slate-500">Created</dt><dd class="font-semibold">${marker.dataset.date}</dd>
                    <dt class="text-slate-500">Position</dt><dd class="font-semibold">X ${marker.dataset.x}%, Y ${marker.dataset.y}%</dd>
                    ${marker.dataset.url ? `<dt class="text-slate-500">URL</dt><dd><a class="font-semibold text-blue-600 hover:text-blue-800" href="${marker.dataset.url}">Open entry</a></dd>` : ''}
                `;
                infoWindow.classList.remove('hidden');
            });
        });

        document.querySelector('.info-close')?.addEventListener('click', () => {
            // Hide the shared window without clearing it; the next marker click will repopulate it.
            infoWindow.classList.add('hidden');
        });
    </script>
</body>
</html>
