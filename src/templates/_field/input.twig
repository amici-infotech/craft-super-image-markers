{# Keep raw IDs for the rendered HTML, and pass namespaced IDs to JavaScript below. #}
{% set inputId = id %}
{% set imageSelectId = assetInput.id %}
{% set markerStageId = "#{id}-stage" %}
{% set inputJsId = id|namespaceInputId %}
{% set imageSelectJsId = assetInput.id|namespaceInputId %}

<div id="{{ inputId }}" class="sim-field">
    {# Markers are serialized into one hidden JSON input so the PHP field can store them in one JSON column. #}
    {{ hiddenInput("#{name}[markers]", markers|json_encode, {
        class: "sim-markers-input",
    }) }}

    {# Reuse Craft's native Assets field input so selection, upload, permissions, and chips behave like core Craft. #}
    <div class="sim-image-picker">
        {% include "_components/fieldtypes/Assets/input.twig" with assetInput only %}
    </div>

    {# The stage is sized by the real image so marker coordinates remain accurate and uncropped. #}
    <div id="{{ markerStageId }}" class="sim-stage {{ imageUrl ? "" : "is-empty" }}">
        <div class="sim-empty">
            {{ "Select an image to start placing markers."|t("super-image-markers") }}
        </div>
        <img class="sim-image" src="{{ imageUrl ?? "" }}" alt="">
        {# JavaScript renders draggable marker buttons into this layer. #}
        <div class="sim-marker-layer"></div>
    </div>

    <div class="flex sim-actions">
        <button type="button" class="btn sim-add-marker">
            {{ "Add marker"|t("super-image-markers") }}
        </button>
    </div>

    {# Marker rows are rendered client-side so dragging, sorting, color changes, and entry selection stay in sync. #}
    <table class="data fullwidth sim-marker-table">
        <thead>
            <tr>
                {# Sort handle / marker number column. #}
                <th scope="col" class="thin"></th>
                <th scope="col">{{ "Entry"|t("super-image-markers") }}</th>
                <th scope="col">{{ "X"|t("super-image-markers") }}</th>
                <th scope="col">{{ "Y"|t("super-image-markers") }}</th>
                {# Color picker and remove action column. #}
                <th scope="col" class="thin"></th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

{% js %}
{# Boot the Garnish field controller with the current image, marker rows, and source restrictions. #}
new Craft.SuperImageMarkersInput({
    id: {{ inputJsId|json_encode|raw }},
    imageSelectId: {{ imageSelectJsId|json_encode|raw }},
    fieldId: {{ field.id|json_encode|raw }},
    entrySources: {{ entrySources|json_encode|raw }},
    image: {{ image ? {
        id: image.id,
        title: image.title,
        url: imageUrl,
    }|json_encode|raw : "null" }},
    markers: {{ markers|json_encode|raw }},
});
{% endjs %}
